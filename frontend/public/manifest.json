{
  "manifest_version": 3,
  "name": "Kaczek",
  "version": "1.0",
  "description": "Wtyczka sprawdzająca rzetelność ogłoszeń na OLX.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Otwórz Kaczka"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}